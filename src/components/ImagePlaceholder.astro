---
export interface Props {
  src?: string;
  alt?: string;
  label?: string;
  shape?: 'rect' | 'circle';
  ratio?: string;
  class?: string;
}

const { src, alt = '', label = 'Image', shape = 'rect', ratio = '1 / 1', class: className } = Astro.props;
---

{
  src ? (
    <img
      src={src}
      alt={alt}
      class:list={['media', `media-${shape}`, className]}
      style={{ aspectRatio: ratio }}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <div
      class:list={['media', 'media-placeholder', `media-${shape}`, className]}
      style={{ aspectRatio: ratio }}
      role="img"
      aria-label={alt || label}
    >
      <svg
        width="26"
        height="26"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.3"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <path d="m21 15-5-5L5 21" />
      </svg>
      <span class="media-label">{label}</span>
    </div>
  )
}

<style>
  .media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-rect {
    border-radius: var(--radius-md);
  }

  .media-circle {
    border-radius: 50%;
  }

  .media-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-align: center;
    padding: var(--space-2);
    background: linear-gradient(155deg, var(--color-neutral-200), var(--color-neutral-300));
    color: var(--color-neutral-600);
    border: 6px solid var(--color-surface);
    outline: 1px solid var(--color-divider);
    box-sizing: border-box;
  }

  .media-placeholder.media-circle {
    border-width: 2px;
  }

  .media-label {
    font-family: var(--font-heading);
    font-size: 11px;
    letter-spacing: 0.02em;
  }
</style>
