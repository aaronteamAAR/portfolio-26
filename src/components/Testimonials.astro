---
import { testimonials } from '../data/testimonials';
import ImagePlaceholder from './ImagePlaceholder.astro';
---

<section id="testimonials" class="section testimonials" aria-labelledby="testimonials-heading" data-reveal>
  <p class="kicker">05 — Testimonials</p>
  <h2 id="testimonials-heading" class="section-title testimonials-title">
    What it's like to work together.
  </h2>
  <ul class="testimonials-grid">
    {
      testimonials.map((testimonial) => (
        <li>
          <figure class="testimonial-card">
            <span class="testimonial-mark" aria-hidden="true">&ldquo;</span>
            <blockquote class="testimonial-quote">
              <p>{testimonial.quote}</p>
            </blockquote>
            <figcaption class="testimonial-author">
              <ImagePlaceholder
                shape="circle"
                ratio="1 / 1"
                label="Photo"
                alt={testimonial.name}
                class="testimonial-avatar"
              />
              <div>
                <p class="testimonial-name">{testimonial.name}</p>
                <p class="testimonial-role text-muted">{testimonial.role}</p>
              </div>
            </figcaption>
          </figure>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .testimonials-title {
    margin-bottom: 48px;
    max-width: 18ch;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 22px;
  }

  .testimonial-card {
    height: 100%;
    box-sizing: border-box;
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-md);
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 0;
  }

  .testimonial-mark {
    font-family: var(--font-display);
    font-size: 54px;
    line-height: 0.6;
    height: 26px;
    color: var(--color-accent);
  }

  .testimonial-quote {
    flex: 1;
    margin: 0;
  }

  .testimonial-quote p {
    font-family: var(--font-body);
    font-size: 16.5px;
    line-height: 1.7;
    margin: 0;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .testimonial-avatar {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .testimonial-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }

  .testimonial-role {
    font-size: 12.5px;
    margin: 0;
  }
</style>
