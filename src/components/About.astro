---
const tags = [
  'Short-Form Video',
  'Community Engagement',
  'Organic Growth',
  'Hook Writing',
  'Content Strategy',
  'Performance Reporting',
  'AI-Assisted Workflows',
];
---

<section id="about" class="section about" aria-labelledby="about-heading" data-reveal>
  <hr class="hr" style="margin-bottom: var(--space-8);" />
  <div class="about-grid">
    <div>
      <p class="kicker">01 — About</p>
      <h2 id="about-heading" class="section-title about-title">
        A partner for brands that take organic growth seriously.
      </h2>
    </div>
    <div class="about-copy">
      <p>
        I'm Aaron Chris Chuku, a social media and community manager who's spent the last three
        years turning organic content into measurable growth for e-commerce and consumer-tech
        brands. Across roles with Aura Displays, The Portable Monitor, and Acco Shops, my work
        has generated <em>500M+ organic views</em> and <em>615M+ cross-platform impressions</em>
        — including a 2.01M-follower community and a single Reel that reached 101M views.
      </p>
      <p>
        My process runs the full cycle: trend research and hook writing, video direction and
        editing, daily community management across comments and DMs, and performance reporting
        that shapes the next round of content. I lean on AI tools — ChatGPT, Claude, Canva's
        Magic Studio, CapCut — as a production multiplier, not a replacement for brand judgment.
      </p>
      <ul class="about-tags">
        {
          tags.map((tag) => (
            <li>
              <span class="tag tag-outline">{tag}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.4fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: start;
  }

  .about-title {
    margin-top: 18px;
  }

  .about-copy p {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.75;
    text-align: justify;
    hyphens: auto;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
