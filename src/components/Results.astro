---
import { results } from '../data/results';
---

<section id="results" class="section results" aria-labelledby="results-heading" data-reveal>
  <p class="kicker">03 — Results</p>
  <h2 id="results-heading" class="section-title results-title">
    Numbers that mattered to the people I worked with.
  </h2>
  <ul class="results-grid">
    {
      results.map((result) => (
        <li class="results-cell">
          <p class="results-value tnum">{result.value}</p>
          <p class="results-label">{result.label}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .results-title {
    margin-bottom: 48px;
    max-width: 20ch;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1px;
    background: var(--color-divider);
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .results-cell {
    background: var(--color-bg);
    padding: 34px 26px;
  }

  .results-value {
    font-family: var(--font-heading);
    font-size: clamp(42px, 5vw, 60px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .results-label {
    margin: 12px 0 0;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }
</style>
