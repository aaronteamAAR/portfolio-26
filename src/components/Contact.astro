---
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<section id="contact" class="contact" aria-labelledby="contact-heading" data-reveal>
  <div class="contact-inner">
    <p class="kicker contact-kicker">08 — Contact</p>
    <h2 id="contact-heading" class="section-title contact-title">
      Let's build something worth belonging to.
    </h2>
    <p class="contact-lede text-muted">
      Tell me about your brand, your platforms, and where things currently stand — I'll follow up
      within a couple of days with next steps.
    </p>
    <div class="contact-actions">
      <a class="btn btn-primary" href={`mailto:${site.email}`}>
        <Icon name="mail" size={17} />
        Email
      </a>
    </div>
    <p class="contact-meta text-muted">{site.location} · {site.handle}</p>
  </div>
</section>

<style>
  .contact {
    background: var(--color-surface);
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
  }

  .contact-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(72px, 10vw, 132px) var(--section-pad-x);
    text-align: center;
  }

  .contact-kicker {
    text-align: center;
  }

  .contact-title {
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 20px 0 22px;
  }

  .contact-lede {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.8vw, 19px);
    line-height: 1.7;
    max-width: 46ch;
    margin: 0 auto 40px;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }

  .contact-meta {
    margin: 22px 0 0;
    font-size: 13.5px;
  }
</style>
