---
import { work } from '../data/work';
import ImagePlaceholder from './ImagePlaceholder.astro';
---

<section id="work" class="section work" aria-labelledby="work-heading" data-reveal>
  <p class="kicker">04 — Selected Work</p>
  <h2 id="work-heading" class="section-title work-title">A few engagements I'm proud of.</h2>
  <ul class="work-grid">
    {
      work.map((item) => (
        <li class="work-card">
          <ImagePlaceholder
            shape="rect"
            ratio="16 / 10"
            label={`Add cover image: ${item.client}`}
            alt={`${item.client} project cover`}
            class="work-cover"
          />
          <div class="work-body">
            <div class="work-meta">
              <span>
                <span class="work-meta-label">Client</span>
                {item.client}
              </span>
              <span>
                <span class="work-meta-label">Industry</span>
                {item.industry}
              </span>
              <span>
                <span class="work-meta-label">Role</span>
                {item.role}
              </span>
            </div>
            <h3 class="work-card-title">{item.title}</h3>
            <p class="work-description text-muted">{item.description}</p>
            <div class="work-metric">
              <span class="work-metric-value tnum">{item.metric}</span>
              <span class="work-metric-label">{item.metricLabel}</span>
            </div>
            <ul class="work-tags">
              {item.tags.map((tag) => (
                <li>
                  <span class="tag tag-neutral">{tag}</span>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .work-title {
    margin-bottom: 48px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 26px;
  }

  .work-card {
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    transition:
      transform 0.25s,
      box-shadow 0.25s;
  }

  .work-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .work-cover {
    border-radius: 0;
  }

  .work-body {
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-size: 12px;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }

  .work-meta-label {
    display: block;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-accent-ink);
  }

  .work-card-title {
    font-size: 24px;
    margin: 0;
  }

  .work-description {
    font-size: 14.5px;
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .work-metric {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 14px;
    border-top: 1px solid var(--color-divider);
  }

  .work-metric-value {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--color-accent-ink);
  }

  .work-metric-label {
    font-size: 13px;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
