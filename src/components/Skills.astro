---
import { skillGroups, education } from '../data/skills';
---

<section id="skills" class="section skills" aria-labelledby="skills-heading" data-reveal>
  <div class="skills-grid">
    <div>
      <p class="kicker">06 — Skills & Tools</p>
      <h2 id="skills-heading" class="section-title skills-title">
        The platforms and craft behind the work.
      </h2>
    </div>
    <div class="skill-groups">
      {
        skillGroups.map((group) => (
          <div class="skill-group">
            <p class="skill-group-title">{group.title}</p>
            <ul class="skill-tags">
              {group.items.map((item) => (
                <li>
                  <span class="tag tag-outline">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
  <p class="skills-education text-muted">
    <span class="skills-education-label">Education</span>
    {education.degree} · {education.note}
  </p>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.4fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: start;
  }

  .skills-title {
    margin-top: 18px;
  }

  .skill-groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 26px;
  }

  .skill-group-title {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    margin: 0 0 11px;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skills-education {
    margin: 40px 0 0;
    padding-top: 22px;
    border-top: 1px solid var(--color-divider);
    font-size: 13.5px;
  }

  .skills-education-label {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-text);
    margin-right: 8px;
  }

  @media (max-width: 860px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
