---
import { site } from '../data/site';
import Icon from './Icon.astro';
import ImagePlaceholder from './ImagePlaceholder.astro';
---

<section id="hero" class="hero" aria-label="Introduction">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="hero-kicker">
        <span class="hero-kicker-line" aria-hidden="true"></span>
        {site.role}
      </p>
      <h1 class="hero-title">
        I build communities people <em>actually</em> want to be part of.
      </h1>
      <p class="hero-lede text-muted">{site.description}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#contact">
          Work With Me
          <Icon name="arrow-right" size={17} />
        </a>
        <a class="btn btn-secondary" href="#work">View My Work</a>
      </div>
      <dl class="hero-stats">
        {
          site.heroStats.map((stat, index) => (
            <>
              {index > 0 && <span class="hero-stat-divider" aria-hidden="true" />}
              <div class="hero-stat">
                <dt class="hero-stat-value tnum">{stat.value}</dt>
                <dd class="hero-stat-label">{stat.label}</dd>
              </div>
            </>
          ))
        }
      </dl>
    </div>
    <figure class="hero-portrait">
      <ImagePlaceholder shape="rect" ratio="4 / 5" label="Add portrait: /images/portrait.jpg" alt="Portrait of Aaron Chris" />
      <figcaption>{site.name}</figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 120px) clamp(20px, 5vw, 56px) clamp(48px, 7vw, 96px);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-heading);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-ink);
    margin: 0 0 28px;
  }

  .hero-kicker-line {
    width: 26px;
    height: 1px;
    background: var(--color-accent);
  }

  .hero-title {
    font-size: clamp(44px, 6.4vw, 82px);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 26px;
  }

  .hero-title em {
    color: var(--color-accent-ink);
    font-style: italic;
  }

  .hero-lede {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.7vw, 19px);
    line-height: 1.65;
    max-width: 40ch;
    margin: 0 0 36px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 22px;
    margin: 44px 0 0;
    padding-top: 30px;
    border-top: 1px solid var(--color-divider);
  }

  .hero-stat-value {
    font-family: var(--font-heading);
    font-size: 30px;
    line-height: 1;
  }

  .hero-stat-label {
    margin: 5px 0 0;
    font-size: 12px;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }

  .hero-stat-divider {
    width: 1px;
    height: 34px;
    background: var(--color-divider);
  }

  .hero-portrait {
    justify-self: center;
    width: 100%;
    max-width: 420px;
  }

  .hero-portrait figcaption {
    text-align: center;
    margin-top: 12px;
    font-style: italic;
    font-size: 14px;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-portrait {
      order: -1;
      max-width: 340px;
    }
  }
</style>
